set statusbar-h-padding 0
set statusbar-v-padding 0
set guioptions none

set zoom-step 50
set scroll-step 150
set scroll-hstep 150

set page-cache-size 100

map [fullscreen]

map [fullscreen] K zoom in
map [fullscreen] J zoom out

map [fullscreen] u scroll half-up
map [fullscreen] d scroll half-dow

map [fullscreen] <A-k> navigate previous
map [fullscreen] <A-j> navigate next
map <A-k> navigate previous
map <A-j> navigate next

map K zoom in
map J zoom out

map u scroll half-up
map d scroll half-down

set selection-clipboard clipboard
set selection-notification false

set recolor "false"

